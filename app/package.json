{
  "name": "djason-chery-nuxt-fullstack",
  "private": true,
  "description": "Nuxt 4 fullstack application with Nitro for djason-chery.dev — integrated back and front",
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_NO_WARNINGS=1 nuxt dev",
    "build": "cross-env NODE_ENV=production nuxt build && npm run copy-wasm",
    "start": "node --env-file=.env.production .output/server/index.mjs",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "copy-wasm": "node scripts/post-build-copy-wasm.js"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.2.0",
    "@nuxt/image": "^2.0.0",
    "@nuxtjs/robots": "^6.1.1",
    "@nuxtjs/sitemap": "^8.2.1",
    "@pinia/nuxt": "^0.11.3",
    "bcryptjs": "^3.0.3",
    "cookie": "^1.1.1",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "entities": "^8.0.0",
    "gsap": "^3.15.0",
    "html2pdf.js": "^0.14.0",
    "nodemailer": "^9.0.3",
    "nuxt": "^4.4.8",
    "pinia": "^3.0.4",
    "sql.js": "^1.14.1",
    "stripe": "^22.2.1",
    "vue": "^3.5.38",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "baseline-browser-mapping": "^2.10.37"
  }
}